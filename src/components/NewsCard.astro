---
interface Props {
  highlight: {
    id: number;
    tag: string;
    category: string;
    symbols: string[];
    title: string;
    summary: string;
    sources: string[];
    hotness?: number;
  };
  featured?: boolean;
}

const { highlight, featured = false } = Astro.props;
const hotness = highlight.hotness || 80;
const goldDots = Math.min(10, Math.floor(hotness / 10));
const grayDots = 10 - goldDots;

const hotTagClass = highlight.tag === "最热" ? "bg-red-900/40 text-red-400" : "bg-orange-900/40 text-orange-400";
const containerClass = featured ? "card-dark p-8 mb-6" : "card-dark p-6";
const titleClass = featured ? "text-2xl font-bold text-white mb-4" : "text-xl font-bold text-white mb-3";
---

<div class={`${containerClass}`}>
  <div class="flex justify-between mb-4">
    <div class="flex gap-2 text-xs">
      <span class={`${hotTagClass} text-[10px] px-2 py-0.5 rounded uppercase font-bold`}>{highlight.tag}</span>
      <span class="bg-zinc-800 text-zinc-400 text-[10px] px-2 py-0.5 rounded uppercase font-bold">{highlight.category}</span>
    </div>
    <div class="flex gap-2">
      {highlight.symbols.map(s => <span class="text-green-500 font-mono text-xs">{s}</span>)}
    </div>
  </div>
  
  <h3 class={titleClass}>{highlight.title}</h3>
  <p class="text-zinc-400 leading-relaxed mb-6 text-sm">{highlight.summary}</p>
  
  <div class="flex justify-between items-center">
    <div class="flex gap-4 text-[10px] font-bold text-zinc-500 uppercase">
      {highlight.sources.map(s => <span>{s}</span>)}
    </div>
    <div class="flex items-center gap-2">
      <div class="flex gap-1">
        {Array.from({ length: 10 }).map((_, i) => (
          <span class={`w-1.5 h-1.5 rounded-full ${i < hotness ? 'bg-gold shadow-[0_0_8px_rgba(212,175,55,0.6)]' : 'bg-zinc-800'}`}></span>
        ))}
      </div>
      <span class="text-zinc-500 text-[10px] font-bold font-mono ml-1">{hotness}/10</span>
    </div>
  </div>
</div>
