---
interface Props {
  highlight: {
    id: number;
    tag: string;
    category: string;
    symbols: string[];
    title: string;
    summary: string;
    sources: string[];
    hotness?: number;
  };
  featured?: boolean;
}

const { highlight, featured = false } = Astro.props;
const hotness = highlight.hotness || 8;
const goldDots = hotness;
const grayDots = 10 - goldDots;

const hotTagClass = highlight.tag === "最热" ? "bg-red-accent/10 text-red" : "bg-orange-400/10 text-gold";
const containerClass = featured ? "card-dark p-5 md:p-8 mb-6" : "card-dark p-4 md:p-6";
const titleClass = featured ? "text-xl md:text-2xl font-bold text-main mb-4" : "text-lg md:text-xl font-bold text-main mb-3";
---

<div class={containerClass}>
  <div class="flex flex-wrap justify-between gap-3 mb-4">
    <div class="flex flex-wrap gap-2 text-xs">
      <span class={`${hotTagClass} text-[10px] px-2 py-0.5 rounded uppercase font-bold tracking-wider`}>{highlight.tag}</span>
      <span class="bg-subtle text-muted text-[10px] px-2 py-0.5 rounded uppercase font-bold tracking-wider">{highlight.category}</span>
    </div>
    <div class="flex flex-wrap gap-2">
      {highlight.symbols.map(s => <span class="text-blue dark:text-green font-mono text-xs font-bold">{s}</span>)}
    </div>
  </div>
  
  <h3 class={`${titleClass} break-words leading-tight`}>{highlight.title}</h3>
  <p class="text-muted leading-relaxed mb-6 text-sm break-words opacity-90">{highlight.summary}</p>
  
  <div class="flex flex-wrap justify-between items-center gap-4 border-t border-color pt-4">
    <div class="flex flex-wrap gap-x-4 gap-y-2 text-[10px] font-bold text-muted uppercase tracking-widest">
      {highlight.sources.map(s => <span>{s}</span>)}
    </div>
    <div class="flex items-center gap-2">
      <div class="flex gap-1">
        {Array.from({ length: 10 }).map((_, i) => {
          const isOn = i < goldDots;
          const isExtreme = highlight.tag === "最热" || highlight.hotness === 10;
          const dotClass = isOn ? (isExtreme ? 'bg-red' : 'bg-gold') : 'bg-subtle';
          const shadowVar = isExtreme ? 'var(--red-rgb)' : 'var(--gold-rgb)';
          return (
            <span class={`w-1.5 h-1.5 rounded-full ${dotClass} ${isOn ? `shadow-[0_0_8px_rgba(${shadowVar},0.4)]` : ''}`}></span>
          );
        })}
      </div>
      <span class="text-muted text-[10px] font-bold font-mono ml-1">{highlight.hotness}/10</span>
    </div>
  </div>
</div>
