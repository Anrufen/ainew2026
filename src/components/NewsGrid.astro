---
import NewsCard from './NewsCard.astro';

interface Props {
  highlights: any[];
}

const { highlights } = Astro.props;
---
<div class="grid grid-cols-2 gap-6">
  {/* The first highlight is featured (full width) in the source mockup, but let's follow the data */}
  {highlights.map((h, index) => (
    <div class={index === 0 ? "col-span-2" : ""}>
      <NewsCard highlight={h} featured={index === 0} />
    </div>
  ))}
</div>
