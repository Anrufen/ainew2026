---
---
<header class="newspaper-header">
  <div class="top-bar">
    <span>VOL. MMXXVI ... NO. 075</span>
    <span class="brand">AI NEW INTELLIGENCE</span>
    <span>{new Date().toLocaleDateString('zh-CN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</span>
  </div>
  <div class="main-title">
    <h1>AI NEWS PORTAL</h1>
  </div>
  <div class="motto">
    "Decoding the Intelligence Age"
  </div>
</header>

<style>
  .newspaper-header {
    text-align: center;
    border-bottom: 4px double var(--ink-black);
    padding-bottom: 1rem;
    margin-bottom: 2rem;
  }
  .top-bar {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    border-bottom: 1px solid var(--border-color);
    padding: 0.3rem 0;
    text-transform: uppercase;
    font-weight: 500;
  }
  .brand {
    font-weight: 900;
  }
  .main-title h1 {
    font-size: 4rem;
    margin: 1rem 0 0.5rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }
  .motto {
    font-style: italic;
    font-family: var(--font-serif);
    color: #666;
  }
  @media (max-width: 768px) {
    .main-title h1 { font-size: 2.5rem; }
    .top-bar span:not(.brand) { display: none; }
  }
</style>
