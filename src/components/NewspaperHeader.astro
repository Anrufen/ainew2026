---
interface Props {
  version?: string;
  dateStr?: string;
}

const { 
  version = "v08:00", 
  dateStr = "2026年3月16日 星期一" 
} = Astro.props;
---
<header class="max-w-7xl mx-auto px-6 pt-12 pb-8">
  <div class="flex justify-between items-start">
    <div data-purpose="logo-area">
      <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-900/30 border border-blue-500/50 mb-6">
        <span class="text-blue-400 text-xs font-bold tracking-widest flex items-center">
          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          AI DAILY BRIEFING
        </span>
      </div>
      <h1 class="text-6xl font-black text-white mb-4 tracking-tight">AI 科技日报</h1>
      <p class="text-gray-400 text-xl">洞察前沿科技动态，把握市场投资先机</p>
    </div>
    <div class="text-right" data-purpose="date-info">
      <p class="text-gray-500 text-sm">{dateStr}</p>
      <p class="text-gray-600 text-[10px] font-medium tracking-widest mt-1">BY @秦彦</p>
      <div class="inline-block mt-3 px-3 py-1 bg-zinc-800 rounded text-gray-400 text-xs font-mono">{version}</div>
    </div>
  </div>
  <div class="h-px w-full bg-zinc-800 mt-12"></div>
</header>
