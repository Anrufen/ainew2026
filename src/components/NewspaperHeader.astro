---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  version?: string;
  dateStr?: string;
}

const { 
  version = "v08:00", 
  dateStr: initialDateStr
} = Astro.props;

// Format date if it's ISO or just use provided/default
let dateStr = initialDateStr;
if (!dateStr) {
  try {
    const d = version.includes('T') ? new Date(version) : new Date();
    if (!isNaN(d.getTime())) {
      dateStr = d.toLocaleDateString('zh-CN', { 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric', 
        weekday: 'long' 
      });
    } else {
      dateStr = "2026年3月16日 星期一";
    }
  } catch (e) {
    dateStr = "2026年3月16日 星期一";
  }
}

// Clean version string for display (just show time part or vXX:XX)
const displayVersion = version.includes('T') ? `v${version.split('T')[1].substring(0, 5)}` : version;
---
<header class="max-w-7xl mx-auto px-6 pt-12 pb-8">
  <div class="flex flex-wrap items-center justify-between gap-6 mb-10">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 bg-gold flex items-center justify-center rounded-sm shadow-[4px_4px_0px_0px_rgba(0,0,0,0.1)]">
        <span class="text-black font-black text-2xl italic">AI</span>
      </div>
      <div>
        <span class="text-gold font-bold tracking-[0.3em] text-[10px] md:text-xs">
          AI DAILY BRIEFING
        </span>
      </div>
    </div>
    <ThemeToggle />
  </div>

  <div class="flex flex-col md:flex-row justify-between items-start gap-8">
    <div data-purpose="logo-area" class="w-full md:w-auto">
      <div class="inline-flex items-center px-3 py-1 rounded-full badge-blue mb-6 border">
        <span class="text-blue text-xs font-bold tracking-widest flex items-center">
          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          洞察前沿科技
        </span>
      </div>
      <h1 class="text-2xl sm:text-4xl md:text-6xl font-black text-main mb-4 tracking-tight break-words">AI 科技日报</h1>
      <p class="text-muted text-base md:text-xl">洞察前沿科技动态，把握市场投资先机</p>
    </div>
    <div class="w-full md:text-right md:w-auto overflow-hidden" data-purpose="date-info">
      <p class="text-muted text-sm break-words">{dateStr}</p>
      <p class="text-muted/60 text-[10px] font-medium tracking-widest mt-1 uppercase">By Qin Yan</p>
      <div class="inline-block mt-3 px-3 py-1 bg-subtle rounded text-muted text-xs font-mono">{displayVersion}</div>
    </div>
  </div>
  <div class="h-px w-full border-t border-color mt-12"></div>
</header>
