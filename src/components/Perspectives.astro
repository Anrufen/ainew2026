---
interface Props {
  perspectives: {
    role: string;
    items: string[];
  }[];
}

const { perspectives } = Astro.props;

const roleIcons: Record<string, string> = {
  'AI 产品经理': '📊',
  '自媒体人': '📱',
  '科技极客': '🛠️'
};
---

<div class="grid grid-cols-3 gap-6">
  {perspectives.map(p => (
    <div class="card-dark p-8">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-10 h-10 bg-zinc-800 rounded-lg flex items-center justify-center">
          <span class="text-xl">{roleIcons[p.role] || '💡'}</span>
        </div>
        <h4 class="text-white font-bold">{p.role}</h4>
      </div>
      <ul class="space-y-6">
        {p.items.map(item => (
          <li class="flex gap-3 text-sm text-zinc-400 leading-relaxed">
            <span class="text-blue-500 mt-1.5">•</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
