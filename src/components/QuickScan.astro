---
const { scan } = Astro.props;

interface ScanGroup {
  group: string;
  summary: string;
  sources: string[];
  note?: string;
  type?: 'science' | 'policy' | 'market' | 'sport' | 'game' | 'product';
}
---

<div class="grid grid-cols-2 gap-6">
  {scan.map((item: ScanGroup) => (
    <div class="card-dark p-6">
      <div class="flex justify-between items-center mb-4">
        <h4 class="font-bold text-white">{item.group}</h4>
        <span class="text-zinc-500 text-[10px] uppercase font-bold tracking-widest">{item.sources.length} 来源</span>
      </div>
      <p class="text-zinc-400 text-sm mb-4 leading-relaxed">{item.summary}</p>
      
      {item.note && (
        <div class={`pl-3 border-l-2 ${item.type === 'science' || item.type === 'policy' || item.type === 'market' || item.type === 'product' ? 'border-blue-500' : 'border-zinc-700'} py-1`}>
          <p class="text-zinc-500 text-xs">{item.note}</p>
        </div>
      )}
    </div>
  ))}
</div>
