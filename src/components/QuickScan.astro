---
interface ScanItem {
  group: string;
  summary: string;
  note?: string;
  sources: string[];
}

interface Props {
  scan: ScanItem[];
}

const { scan } = Astro.props;

// 模拟时间
const times = ['10:24 AM', '09:15 AM', '08:30 AM', '07:45 AM', '07:00 AM', '06:30 AM'];
---
<div class="quick-scan card">
  <div class="timeline">
    {scan.map((item, index) => (
      <div class="timeline-item">
        <div class="timeline-marker">
          <div class={`marker-dot ${index === 0 ? 'active' : ''}`}></div>
          {index < scan.length - 1 && <div class="marker-line"></div>}
        </div>
        <div class="timeline-content">
          <div class="time-label">{times[index] || '06:00 AM'}</div>
          <p class="scan-text">{item.summary}</p>
          <a href="#" class="source-btn">来源</a>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .quick-scan {
    padding: 1.5rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: flex;
    gap: 1rem;
    min-height: 80px;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 16px;
    flex-shrink: 0;
  }

  .marker-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-color);
    flex-shrink: 0;
    margin-top: 0.35rem;
  }

  .marker-dot.active {
    background: var(--primary-blue);
    box-shadow: 0 0 0 4px var(--primary-blue-light);
  }

  .marker-line {
    width: 2px;
    flex: 1;
    background: var(--border-light);
    margin-top: 0.5rem;
  }

  .timeline-content {
    flex: 1;
    padding-bottom: 1.25rem;
  }

  .time-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .scan-text {
    font-size: 0.95rem;
    color: var(--text-primary);
    line-height: 1.5;
    margin: 0 0 0.5rem 0;
  }

  .source-btn {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--primary-blue);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .source-btn:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .quick-scan {
      padding: 1rem;
    }

    .scan-text {
      font-size: 0.9rem;
    }
  }
</style>
