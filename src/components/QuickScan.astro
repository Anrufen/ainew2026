---
const { scan } = Astro.props;
---
<div class="quick-scan-container">
    {scan.map((group) => (
        <div class="scan-item">
            <div class="scan-header">
                <span class="scan-group">{group.group}</span>
                <div class="scan-sources">
                    {group.sources.map(s => <span class="source-tag">{s}</span>)}
                </div>
            </div>
            <p class="scan-content">{group.summary}</p>
            {group.note && <p class="scan-note">💡 {group.note}</p>}
        </div>
    ))}
</div>

<style>
    .quick-scan-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
        padding-bottom: 2rem;
    }
    .scan-item {
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1rem;
    }
    .scan-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }
    .scan-group {
        font-weight: 700;
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
    }
    .source-tag {
        font-size: 0.7rem;
        background: #f0f0f0;
        padding: 2px 6px;
        margin-left: 4px;
        border-radius: 2px;
        color: #666;
    }
    .scan-content {
        font-size: 0.95rem;
        line-height: 1.5;
        margin-bottom: 0.5rem;
    }
    .scan-note {
        font-size: 0.85rem;
        color: #555;
        font-style: italic;
        background: #f9f9f9;
        padding: 0.5rem;
        border-left: 3px solid var(--accent-color);
    }
</style>
