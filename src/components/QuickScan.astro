---
const { scan } = Astro.props;

interface ScanGroup {
  group: string;
  summary: string;
  sources: string[];
  note?: string;
  type?: 'science' | 'policy' | 'market' | 'sport' | 'game' | 'product';
}
---

<div class="flex flex-wrap gap-4 md:gap-6">
  {scan.map((item: ScanGroup) => (
    <div class="card-dark p-4 md:p-6 flex-grow basis-full lg:basis-[calc(50%-12px)] min-w-0 lg:min-w-[400px]">
      <div class="flex flex-wrap justify-between items-center gap-2 mb-4">
        <h4 class="font-bold text-main break-words">{item.group}</h4>
        <span class="text-muted text-[10px] uppercase font-bold tracking-widest flex-shrink-0 opacity-80">{item.sources.length} 来源</span>
      </div>
      <p class="text-muted text-sm mb-4 leading-relaxed break-words">{item.summary} </p>
      
      {item.note && (
        <div class={`pl-3 border-l-2 ${item.type === 'science' || item.type === 'policy' || item.type === 'market' || item.type === 'product' ? 'border-blue-500' : 'border-color'} py-1`}>
          <p class="text-muted text-xs break-words italic">{item.note}</p>
        </div>
      )}
    </div>
  ))}
</div>
