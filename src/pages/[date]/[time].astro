---
import '../../styles/magazine.css';
import NewspaperHeader from '../../components/NewspaperHeader.astro';
import NewsGrid from '../../components/NewsGrid.astro';
import StockAnalysis from '../../components/StockAnalysis.astro';
import Perspectives from '../../components/Perspectives.astro';
import QuickScan from '../../components/QuickScan.astro';
import ContentIdeas from '../../components/ContentIdeas.astro';
import { getNewsByVersion } from '../../lib/kv';

export function getStaticPaths() {
  // Since we are using Cloudflare SSR (Server Side Rendering), we might not need getStaticPaths 
  // if output is set to 'server' or 'hybrid'. 
  // But for a starter template, let's provide a way to handle this.
  return [
    { params: { date: '2026-03-15', time: '22-50' } },
  ];
}

const { date, time } = Astro.params;
const version = `${date}T${time.replace('-', ':')}`;
const env = Astro.locals.runtime?.env;
const newsData = await getNewsByVersion(version, env);

if (!newsData) {
  return Astro.redirect('/404');
}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 科技日报 - 历史版本 - {version}</title>
</head>
<body class="antialiased pb-20">
    <div class="max-w-7xl mx-auto">
        <NewspaperHeader version={newsData.version} />
        
        <main class="px-6">
            <div class="mb-10 flex items-center gap-2 text-zinc-500">
                <a href="/" class="hover:text-white transition-colors">首页</a>
                <span>/</span>
                <span class="text-zinc-300">历史快照 {version}</span>
            </div>

            <!-- Top Highlights -->
            <section class="mb-16">
                <div class="flex items-center gap-4 mb-8">
                    <div class="flex items-center gap-3">
                        <div class="p-2 bg-blue-600/20 rounded-lg">
                            <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-white">历史热点聚焦</h2>
                    </div>
                    <span class="text-zinc-500 text-xs tracking-widest font-bold uppercase mt-1">TOP HIGHLIGHTS</span>
                </div>
                <NewsGrid highlights={newsData.highlights} />
            </section>

            <!-- Quick Scan -->
            {newsData.quick_scan && (
                <section class="mb-16">
                    <div class="flex items-center gap-4 mb-8">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-blue-600/20 rounded-lg">
                                <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                            </div>
                            <h2 class="text-2xl font-bold text-white">快速扫描</h2>
                        </div>
                        <span class="text-zinc-500 text-xs tracking-widest font-bold uppercase mt-1">QUICK SCAN</span>
                    </div>
                    <QuickScan scan={newsData.quick_scan} />
                </section>
            )}

            <!-- Market Impact -->
            <section class="mb-16">
                <div class="flex items-center gap-4 mb-8">
                    <div class="flex items-center gap-3">
                        <div class="p-2 bg-green-600/20 rounded-lg">
                            <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-white">股票影响分析</h2>
                    </div>
                    <span class="text-zinc-500 text-xs tracking-widest font-bold uppercase mt-1">MARKET IMPACT</span>
                </div>
                <StockAnalysis stocks={newsData.stock_analysis} />
            </section>

            <!-- Expert Perspectives -->
            <section class="mb-16">
                <div class="flex items-center gap-4 mb-8">
                    <div class="flex items-center gap-3">
                        <div class="p-2 bg-purple-600/20 rounded-lg">
                            <svg class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-white">多维视角</h2>
                    </div>
                    <span class="text-zinc-500 text-xs tracking-widest font-bold uppercase mt-1">EXPERT PERSPECTIVES</span>
                </div>
                <Perspectives perspectives={newsData.perspectives} />
            </section>

            <!-- Content Ideas -->
            {newsData.content_ideas && (
                <section class="mb-16">
                    <div class="flex items-center gap-4 mb-8">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-yellow-600/20 rounded-lg">
                                <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                            </div>
                            <h2 class="text-2xl font-bold text-white">内容选题灵感</h2>
                        </div>
                        <span class="text-zinc-500 text-xs tracking-widest font-bold uppercase mt-1">CONTENT IDEAS</span>
                    </div>
                    <ContentIdeas ideas={newsData.content_ideas} />
                </section>
            )}
        </main>
        
        <footer class="mt-20 text-center border-t border-zinc-800 pt-8 pb-12 text-zinc-500 text-xs px-6">
            © 2026 AI NEW INTELLIGENCE. 本页内容由智能工作流自动生成，不构成投资建议。
        </footer>
    </div>
</body>
</html>
