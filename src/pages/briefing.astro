---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 科技日报 | {newsData.version}</title>
  <meta name="description" content="洞察前沿科技动态，把握市场投资先机">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="briefing-container">
    <BriefingHeader version={newsData.version} />
    
    <main>
      <HighlightsSection highlights={newsData.highlights} />
      
      <StockSection stocks={newsData.stock_analysis} />
      
      <PerspectivesSection perspectives={newsData.perspectives} />
      
      <ContentIdeasSection ideas={newsData.content_ideas} />
      
      <QuickScanSection scans={newsData.quick_scan} />
    </main>
    
    <footer class="briefing-footer">
      <p class="footer-text">AI Daily Briefing - 智能新闻聚合系统</p>
      <p class="footer-disclaimer">本页内容由 AI 自动生成，仅供参考，不构成投资建议</p>
    </footer>
  </div>
</body>
</html>
