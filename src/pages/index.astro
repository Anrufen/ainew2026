---
import '../styles/magazine.css';
import NewspaperHeader from '../components/NewspaperHeader.astro';
import NewsGrid from '../components/NewsGrid.astro';
import StockAnalysis from '../components/StockAnalysis.astro';
import Perspectives from '../components/Perspectives.astro';
import QuickScan from '../components/QuickScan.astro';
import ContentIdeas from '../components/ContentIdeas.astro';
import { getLatestNews, getNewsByVersion } from '../lib/kv';

// 获取 Cloudflare 环境环境变量
const env = Astro.locals.runtime?.env;
const newsData = await getLatestNews(env);
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 每日简报 | 深度洞察科技前沿</title>
    <meta name="description" content="AI 每日简报 - 深度洞察科技前沿，为您提供最新的人工智能行业资讯、股票分析和专家视角。">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
    <div class="newspaper-container">
        <NewspaperHeader />
        
        <main>
            <!-- 热点聚类 -->
            <div class="section-title">
                <span class="icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                </span>
                <span>热点聚类</span>
            </div>
            
            <NewsGrid highlights={newsData.highlights} />
            
            <!-- 快讯聚合 -->
            {newsData.quick_scan && newsData.quick_scan.length > 0 && (
                <>
                    <div class="section-title">
                        <span class="icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                            </svg>
                        </span>
                        <span>快讯聚合</span>
                    </div>
                    <QuickScan scan={newsData.quick_scan} />
                </>
            )}
            
            <!-- 股票影响分析 -->
            <div class="section-title">
                <span class="icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="20" x2="18" y2="10"></line>
                        <line x1="12" y1="20" x2="12" y2="4"></line>
                        <line x1="6" y1="20" x2="6" y2="14"></line>
                    </svg>
                </span>
                <span>股票影响分析</span>
            </div>
            
            <StockAnalysis stocks={newsData.stock_analysis} />
            
            <!-- 三端视角 -->
            <div class="section-title">
                <span class="icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="8" y1="6" x2="21" y2="6"></line>
                        <line x1="8" y1="12" x2="21" y2="12"></line>
                        <line x1="8" y1="18" x2="21" y2="18"></line>
                        <line x1="3" y1="6" x2="3.01" y2="6"></line>
                        <line x1="3" y1="12" x2="3.01" y2="12"></line>
                        <line x1="3" y1="18" x2="3.01" y2="18"></line>
                    </svg>
                </span>
                <span>三端视角</span>
            </div>
            
            <Perspectives perspectives={newsData.perspectives} />

            <!-- 选题灵感 -->
            {newsData.content_ideas && newsData.content_ideas.length > 0 && (
                <>
                    <div class="section-title">
                        <span class="icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <circle cx="12" cy="12" r="4"></circle>
                                <line x1="4.93" y1="4.93" x2="9.17" y2="9.17"></line>
                                <line x1="14.83" y1="14.83" x2="19.07" y2="19.07"></line>
                                <line x1="14.83" y1="9.17" x2="19.07" y2="4.93"></line>
                                <line x1="4.93" y1="19.07" x2="9.17" y2="14.83"></line>
                            </svg>
                        </span>
                        <span>选题灵感</span>
                    </div>
                    <ContentIdeas ideas={newsData.content_ideas} />
                </>
            )}
        </main>
        
        <footer class="page-footer">
            <span>&copy; 2026 AI Daily Briefing. All rights reserved.</span>
            <span class="designer">
                Designed by 
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <circle cx="12" cy="12" r="10"></circle>
                </svg>
                <span>v0</span>
            </span>
        </footer>
    </div>
</body>
</html>
